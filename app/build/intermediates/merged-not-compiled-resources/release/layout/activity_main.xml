<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- Web Content Area -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <WebView
            android:id="@+id/web_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Translucent floating controller bar at the bottom -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_controller"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/translucent_dark"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center">

            <!-- Back -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Go Back"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_primary" />

            <!-- Forward -->
            <ImageButton
                android:id="@+id/btn_forward"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Go Forward"
                android:src="@drawable/ic_arrow_forward"
                app:tint="@color/text_primary" />

            <!-- Reload -->
            <ImageButton
                android:id="@+id/btn_refresh"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Reload"
                android:src="@drawable/ic_refresh"
                app:tint="@color/text_primary" />

            <!-- Bookmark Toggle -->
            <ImageButton
                android:id="@+id/btn_bookmark"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Toggle Bookmark"
                android:src="@drawable/ic_star_outline"
                app:tint="@color/text_primary" />

            <!-- Bookmarks List -->
            <ImageButton
                android:id="@+id/btn_bookmarks_list"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Bookmarks List"
                android:src="@drawable/ic_bookmarks_list"
                app:tint="@color/text_primary" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Error/Offline screen (No Internet) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_offline_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/translucent_error"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="32dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_cloud_off"
                app:tint="@color/accent_red" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/error_no_internet_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/error_no_internet_desc"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_retry_offline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/accent_red"
                android:paddingHorizontal="24dp"
                android:text="@string/retry"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Error screen (Website Unavailable) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_server_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/translucent_error"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="32dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_error_outline"
                app:tint="@color/accent_red" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/error_unavailable_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/error_unavailable_desc"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_retry_server"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/accent_red"
                android:paddingHorizontal="24dp"
                android:text="@string/retry"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Fullscreen Video Container (placed above everything) -->
    <FrameLayout
        android:id="@+id/layout_fullscreen_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
